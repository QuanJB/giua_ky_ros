<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="chassis_length" value="0.5"/>
    <xacro:property name="chassis_width" value="0.3"/>
    <xacro:property name="wheel_radius" value="0.1"/>

    <link name="base_link"></link>

    <link name="base_footprint"></link>

    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 ${wheel_radius}"/>
    </joint>

    <joint name="chassis_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="-0.1 0 0"/>
    </joint>

    <link name="chassis">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="${chassis_length} ${chassis_width} 0.1"/></geometry>
            <material name="red">
                <color rgba="1.0 0.0 0.0 1.0"/>   
            </material>
        </visual>
        
        <collision>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
            <geometry><box size="0.4 0.15 0.1"/></geometry>
        </collision>
        
        <inertial>
            <origin xyz="0 0 -0.1" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
        </inertial>
    </link>

    <xacro:macro name="rear_wheel" params="prefix y_reflect">
        <joint name="${prefix}_wheel_joint" type="continuous">
            <parent link="chassis"/>
            <child link="${prefix}_wheel"/>
            <origin xyz="-0.15 ${y_reflect * 0.22} 0" rpy="${pi/2} 0 0"/>
            <axis xyz="0 0 -1"/>
            <limit effort="1000.0" velocity="100.0"/>
            <dynamics damping="0.1" friction="0.1"/>
        </joint>
        <link name="${prefix}_wheel">
            <visual>
                <origin xyz="0 0 0.045" rpy="${pi/2} 0 0"/>
                <geometry>
                    <mesh filename="package://robot_description/mesh/wheel.dae" scale="0.005 0.005 0.005"/>
                </geometry>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry><cylinder radius="${wheel_radius}" length="0.05"/></geometry>
            </collision>
            <inertial>
                <mass value="0.5"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
        </link>
    </xacro:macro>

    <xacro:rear_wheel prefix="rear_left" y_reflect="1" />
    <xacro:rear_wheel prefix="rear_right" y_reflect="-1" />

    <xacro:macro name="front_wheel" params="prefix y_reflect">
        <joint name="${prefix}_steer_joint" type="revolute">
            <parent link="chassis"/>
            <child link="${prefix}_steer_link"/>
            <origin xyz="0.15 ${y_reflect * 0.22} 0" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <limit lower="-0.5" upper="0.5" effort="100" velocity="1.0"/>
            <dynamics damping="5.0" friction="2.0"/>
        </joint>
        <link name="${prefix}_steer_link">
            <inertial>
                <mass value="0.2"/>
                <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
          </inertial>
        </link>

        <joint name="${prefix}_wheel_joint" type="continuous">
            <parent link="${prefix}_steer_link"/>
            <child link="${prefix}_wheel"/>
            <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            <axis xyz="0 0 -1"/>
            <limit effort="100.0" velocity="100.0"/>
            <dynamics damping="0.1" friction="0.1"/>
        </joint>
        <link name="${prefix}_wheel">
            <visual>
                <geometry><cylinder radius="${wheel_radius}" length="0.05"/></geometry>
                <material name="blue">
                    <color rgba="0.0 0.0 1.0 1.0"/>
                </material>
            </visual>
            <collision>
                <geometry><cylinder radius="${wheel_radius}" length="0.05"/></geometry>
            </collision>
            <inertial>
                <mass value="0.5"/>
                <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
            </inertial>
        </link>
    </xacro:macro>

    <xacro:front_wheel prefix="front_left" y_reflect="1" />
    <xacro:front_wheel prefix="front_right" y_reflect="-1" />

    <gazebo reference="chassis">
        <material>Gazebo/Red</material>
    </gazebo>

    <gazebo reference="front_left_wheel">
        <material>Gazebo/Blue</material>
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <kp>500000.0</kp>    
        <kd>10.0</kd>        
        <minDepth>0.001</minDepth> </gazebo>

    <gazebo reference="front_right_wheel">
        <material>Gazebo/Blue</material>
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <kp>500000.0</kp>
        <kd>10.0</kd>
        <minDepth>0.001</minDepth>
    </gazebo>

    <gazebo reference="rear_left_wheel">
        <material>Gazebo/Black</material>
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <kp>500000.0</kp>
        <kd>10.0</kd>
        <minDepth>0.001</minDepth>
    </gazebo>

    <gazebo reference="rear_right_wheel">
        <material>Gazebo/Black</material>
        <mu1>1.5</mu1>
        <mu2>1.5</mu2>
        <kp>500000.0</kp>
        <kd>10.0</kd>
        <minDepth>0.001</minDepth>
    </gazebo>

</robot>